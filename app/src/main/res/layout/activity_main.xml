<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0814"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 Broxa — Tempo de Tela"
            android:textColor="#FFD24A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Envia seu tempo de uso pro Broxa Games automaticamente."
            android:textColor="#9aa"
            android:textSize="13sp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quem é você?"
            android:textColor="#ddd"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textColor="#ddd"
            android:textSize="14sp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btnPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Conceder acesso ao uso" />

        <Button
            android:id="@+id/btnSync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Sincronizar agora" />

        <TextView
            android:id="@+id/txtResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#22DDFF"
            android:textSize="13sp"
            android:paddingTop="16dp"
            android:fontFamily="monospace" />
    </LinearLayout>
</ScrollView>
